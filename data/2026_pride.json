      },
      "properties": {
        "title": "Club Church",
        "image": "https://upload.wikimedia.org/wikipedia/commons/9/93/Club_church%2C_Kerkstraat_52%2C_Amsterdam.jpg",
        "description": "Club chUrch is een queer discotheek die bekend staat om haar inclusieve, sekspositieve sfeer en gevarieerde thema-avonden. De club aan de Kerkstraat bestaat sinds 2008.",
        "url": "https://www.clubchurch.nl/"
      },
      "id": "54aa40ba-0c3a-46db-8f08-85722b631f03"
    },
    {
