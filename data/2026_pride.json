      "properties": {
        "title": "Pamela",
        "image": "https://cdn.shopify.com/s/files/1/0018/7793/4115/files/240643361_375294423986175_5078307688267276742_n_1024x1024.jpg?v=1637841997",
        "description": "Bar Pamela (geopend in 2020) is een kleurrijke queer bar in Amsterdam-Oud-West, veelal bezocht op FLINTA-publiek. De bar serveert cocktails en vegan-friendly bites in een creatieve, neonachtige setting met veel kunst en muziek. ’s Avonds verandert Pamela regelmatig in een levendige uitgaansplek met dj-sets, drag en queer events.",
        "url": "https://www.instagram.com/pamela.amsterdam/"
